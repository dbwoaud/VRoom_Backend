# ===== LLM 설정 =====
# LLM_PROVIDER: "openai" (착수보고서에 명시된 GPT-4o-mini) 또는 "groq" (음성 서버 프로토타입과 동일)
LLM_PROVIDER=openai

# provider=openai 일 때
OPENAI_API_KEY=sk-여기에_본인_키
OPENAI_MODEL=gpt-4o-mini

# provider=groq 일 때 (팀이 이미 쓰는 GROQ_API_KEY 그대로 사용 가능)
GROQ_API_KEY=gsk_여기에_groq_키
GROQ_MODEL=llama-3.3-70b-versatile

# ===== TTS 워커(Node B) 주소 =====
# 음성 처리 서버 Readme의 Node B 엔드포인트. 백엔드가 면접관 대사를 여기로 보내 음성을 합성한다.
TTS_WORKER_URL=http://host.docker.internal:8001/process

# ===== 서버 동작 =====
HOST=0.0.0.0
PORT=8080

# Node A(STT)가 백엔드의 /process 응답으로 오디오를 되받길 기대하는 "기존 코드 그대로" 모드면 true.
# 권장값은 false (= 모든 면접관 음성을 백엔드->Unity WebSocket으로 직접 전송).
PROXY_AUDIO_TO_STT=false
